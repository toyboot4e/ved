{
  "name": "@ved/root",
  "version": "0.1.0",
  "private": true,
  "description": "ved monorepo — workspace root (no shipped code).",
  "scripts": {
    "check": "biome check",
    "check:fix": "biome check --fix",
    "check:fix:unsafe": "biome check --fix --unsafe",
    "format": "biome format",
    "format:fix": "biome format --fix",
    "lint": "biome lint",
    "lint:fix": "biome lint --fix",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "dev": "pnpm -C desktop dev",
    "dev:web": "pnpm -C web dev",
    "start": "pnpm -C desktop start",
    "build": "pnpm -C desktop build",
    "build:web": "pnpm -C web build",
    "smoke": "pnpm -C desktop smoke",
    "smoke:mozc": "pnpm -C desktop smoke:mozc",
    "api-docs": "node scripts/gen-api-docs.ts",
    "api-docs:check": "node scripts/gen-api-docs.ts --check"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@ox-content/napi": "^2.76.0",
    "@types/node": "^26.1.0",
    "@vitest/ui": "^4.1.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.5.3"
}
